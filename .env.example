# =============================================================================
# Cognitron — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# In development, all vars are optional — the app falls back to mock data.
# In production, Supabase vars are REQUIRED.
# =============================================================================

# --- Supabase ------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard → Project Settings → API

# Public URL of your Supabase project (required in production)
NEXT_PUBLIC_SUPABASE_URL=

# Public anonymous key — safe for client-side use (required in production)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, NEVER expose to client (optional, for admin ops)
# SUPABASE_SERVICE_ROLE_KEY=

# --- App -----------------------------------------------------------------------

# Public site URL (optional, defaults to https://cognitron.tech)
# NEXT_PUBLIC_SITE_URL=https://cognitron.tech

# --- Analytics -----------------------------------------------------------------

# Google Analytics 4 measurement ID (optional, analytics disabled with placeholder)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel ID (optional, analytics disabled with placeholder)
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXX
